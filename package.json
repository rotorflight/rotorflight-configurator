{
  "name": "rotorflight-configurator",
  "productName": "Rotorflight Configurator",
  "description": "Crossplatform configuration tool for Rotorflight flight control system.",
  "version": "0.0.0",
  "main": "http://localhost:5077/",
  "node-remote": "http://localhost:*",
  "scripts": {
    "lint": "eslint --cache src \"./*.mjs\"",
    "lint:fix": "eslint --fix src \"./*.mjs\"",
    "setup:win": ".\\tools\\windows\\dev.cmd setup",
    "start:win": ".\\tools\\windows\\dev.cmd start",
    "start:win:reset-cache": ".\\tools\\windows\\dev.cmd start-reset",
    "up:win": ".\\tools\\windows\\dev.cmd up",
    "start": "concurrently --kill-others \"pnpm vite\" \"pnpm gulp dev_client\"",
    "prepare": "husky || true"
  },
  "window": {
    "icon": "public/images/rf_icon.png",
    "id": "main-window",
    "min_width": 1024,
    "min_height": 550,
    "title": "Rotorflight Configurator"
  },
  "repository": {
    "type": "git",
    "url": "github.com/rotorflight/rotorflight-configurator"
  },
  "webview": {
    "partitions": [
      {
        "name": "map",
        "accessible_resources": [
          "/src/tabs/map.html",
          "/assets/src/tabs/map.html.js",
          "/assets/modulepreload-polyfill.js",
          "/libraries/openlayers/ol.css",
          "/libraries/openlayers/ol.js",
          "/images/icons/cf_icon_position.png",
          "/images/icons/cf_icon_position_nofix.png"
        ]
      }
    ]
  },
  "author": "The Rotorflight open source project.",
  "license": "GPL-3.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "jbox": "^1.3.3",
    "jquery": "^3.6.0",
    "jquery-textcomplete": "^1.8.5",
    "jquery-touchswipe": "^1.6.19",
    "jquery-ui-npm": "^1.12.0",
    "lru_map": "^0.3.3",
    "select2": "^4.0.13",
    "switchery-latest": "^0.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@floating-ui/dom": "^1.7.6",
    "@fortawesome/fontawesome-free": "^5.13.0",
    "@quanle94/innosetup": "^6.0.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jquery": "^4.0.1",
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.1",
    "archiver": "^8.0.0",
    "command-exists": "^1.2.9",
    "concurrently": "^10.0.3",
    "cordova-lib": "^12.0.2",
    "d3": "^7.9.0",
    "dompurify": "^3.4.11",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "gulp": "^4.0.2",
    "gulp-concat": "~2.6.1",
    "gulp-debian": "^0.1.9",
    "gulp-json-editor": "^2.5.6",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.1.3",
    "gulplog": "^2.2.0",
    "husky": "^9.1.7",
    "i18next": "^26.3.1",
    "i18next-http-backend": "^4.0.0",
    "lint-staged": "^17.0.8",
    "marked": "^18.0.5",
    "microdiff": "^1.5.0",
    "minimist": "^1.2.8",
    "multiple-select": "^1.7.0",
    "nouislider": "^15.8.1",
    "nw-builder": "4.9.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "rpm-builder": "^1.2.1",
    "sass-embedded": "^1.100.0",
    "semver": "^7.8.5",
    "sortablejs": "^1.15.7",
    "svelte": "^5.56.4",
    "svelte-i18next": "^2.2.2",
    "three": "<0.163.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vinyl-source-stream": "^2.0.0",
    "vite": "^8.1.0",
    "wnumb": "^1.2.0"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6"
  }
}
